# Copy to .env and adjust. Used by compose and local tooling.

# Home Assistant — URL as seen FROM the backend container
HA_URL=http://homeassistant:8123
# Long-lived access token (create in HA Profile → Security); empty until you add one
HA_TOKEN=

# P9 optional transcript bridge (default on). Set 0/false/off to disable POST /api/voice/transcript.
VOICE_BRIDGE_ENABLED=

# Ports published on the host
HOMEASSISTANT_PORT=8123
BACKEND_PORT=8000
UI_PORT=5173
OLLAMA_PORT=11434

# Vite dev server proxy target (from UI container use service name; from host use http://127.0.0.1:8000)
VITE_PROXY_TARGET=http://backend:8000

# Ollama NLU fallback — set to true to enable LLM interpretation for unknown phrases
OLLAMA_NLU_ENABLED=false
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT=15
